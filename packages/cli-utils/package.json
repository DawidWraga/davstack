{
  "name": "@davstack/cli-utils",
  "version": "1.2.0",
  "license": "MIT",
  "type": "module",
  "description": "Tiny CLI helper shared by @davstack/logs-server, vitest-server, playwright-server.",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./help": {
      "types": "./dist/cli-help.d.ts",
      "default": "./dist/cli-help.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./dotenv": {
      "types": "./dist/dotenv.d.ts",
      "default": "./dist/dotenv.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "pnpm -w exec vitest run --project cli-utils"
  },
  "files": [
    "dist/**"
  ],
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
