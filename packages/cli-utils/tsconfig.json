{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022"],
		"types": ["node"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": false,
		"resolveJsonModule": true
	},
	"include": ["src/**/*"]
}
