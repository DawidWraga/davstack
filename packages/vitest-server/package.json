{
  "name": "@davstack/vitest-server",
  "version": "1.3.0",
  "license": "MIT",
  "type": "module",
  "description": "Warm vitest daemon for fast TDD reruns. Keeps a long-lived vitest runtime hot so per-file reruns drop from ~50s cold to ~3-15s.",
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "pnpm -w exec vitest run --project vitest-server"
  },
  "bin": {
    "vitest-server": "./bin/vitest-server.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    }
  },
  "files": [
    "bin/**",
    "dist/**"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@davstack/cli-utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@storybook/addon-vitest": ">=10",
    "@vitest/browser": ">=4",
    "vitest": ">=4"
  },
  "peerDependenciesMeta": {
    "@vitest/browser": {
      "optional": true
    },
    "@storybook/addon-vitest": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
