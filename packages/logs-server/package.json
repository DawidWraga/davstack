{
  "name": "@davstack/logs-server",
  "version": "1.3.2",
  "license": "MIT",
  "type": "module",
  "description": "Local Sentry-shaped log sink: ingest envelopes over HTTP, persist to per-repo SQLite, query by trace_id/run_id/level.",
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "pnpm -w exec vitest run --project logs-server"
  },
  "bin": {
    "logs-server": "./bin/logs-server.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    }
  },
  "files": [
    "bin/**",
    "dist/**"
  ],
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "dependencies": {
    "@davstack/cli-utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
