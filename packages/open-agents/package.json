{
  "name": "@davstack/open-agents",
  "version": "1.1.0",
  "license": "MIT",
  "type": "module",
  "description": "Self-waiting Cursor-jobs primitive: delegate scoped explore (read-only) and fast-edit (mechanical) work to cursor-agent, harness-trackable, results persisted per job.",
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "pnpm -w exec vitest run --project open-agents"
  },
  "bin": {
    "explore": "./bin/explore.mjs",
    "fast-edit": "./bin/fast-edit.mjs"
  },
  "exports": {
    ".": "./dist/index.js",
    "./core/jobs": {
      "types": "./dist/core/jobs.d.ts",
      "default": "./dist/core/jobs.js"
    },
    "./core/parse": {
      "types": "./dist/core/parse.d.ts",
      "default": "./dist/core/parse.js"
    },
    "./core/paths": {
      "types": "./dist/core/paths.d.ts",
      "default": "./dist/core/paths.js"
    },
    "./core/deliverable": {
      "types": "./dist/core/deliverable.d.ts",
      "default": "./dist/core/deliverable.js"
    },
    "./adapters/types": {
      "types": "./dist/adapters/types.d.ts",
      "default": "./dist/adapters/types.js"
    },
    "./adapters/cursor": {
      "types": "./dist/adapters/cursor.d.ts",
      "default": "./dist/adapters/cursor.js"
    },
    "./adapters/gemini": {
      "types": "./dist/adapters/gemini.d.ts",
      "default": "./dist/adapters/gemini.js"
    }
  },
  "files": [
    "bin/**",
    "dist/**",
    "docs/**"
  ],
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "dependencies": {
    "@davstack/cli-utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
